{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim"
  ],
  "mcp": {
    "flux": {
      "type": "remote",
      "url": "http://vmcp-flux.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    },
    "homeassistant": {
      "type": "remote",
      "url": "http://vmcp-homeassistant.ai.svc.cluster.local:4483/mcp",
      "enabled": true
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://10.0.2.88:1234/v1"
      },
      "models": {
        "huihui-qwen3-coder-next-abliterated-i1": {
          "name": "huihui-qwen3-coder-next-abliterated (local)"
        },
        "huihui-qwen3.5-122b-a10b-abliterated": {
          "name": "huihui-qwen3.5-122b-a10b-abliterated (local)"
        },
        "huihui-glm-4.5-air-abliterated": {
          "name": "huihui-glm-4.5-air-abliterated (local)"
        }
      }
    }
  }
}